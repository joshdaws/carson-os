{
  "name": "carson-os",
  "version": "0.1.0",
  "private": true,
  "description": "CarsonOS — Your family's values, your family's AI.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @carsonos/server dev",
    "dev:sandbox": "DATA_DIR=$PWD/.sandbox PORT=3301 pnpm --filter @carsonos/server dev",
    "start": "pnpm --filter @carsonos/server start",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @carsonos/db generate",
    "db:migrate": "pnpm --filter @carsonos/db migrate"
  }
}
